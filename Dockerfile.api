FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir "fastapi>=0.110" "uvicorn[standard]>=0.27" "soundfile>=0.12" "numpy>=1.24"

COPY review_api.py feedback_collector.py ./

RUN mkdir -p /app/clips /app/feedback

CMD ["uvicorn", "review_api:app", "--host", "0.0.0.0", "--port", "8081"]
