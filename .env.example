# ESP32 RTSP microphone URL
# Copy this file to .env and set the correct IP address of your ESP32 microphone.
# Example: rtsp://192.168.2.20:8554/audio
ESP32_RTSP_URL=rtsp://192.168.2.20:8554/audio

# Freesound API (optioneel, voor extra trainingsdata)
# Gratis account aanmaken: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=
